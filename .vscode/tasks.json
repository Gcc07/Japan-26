{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Japan 26",
      "type": "shell",
      "command": "mvn javafx:run",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$javac"
    },
    {
      "label": "Compile",
      "type": "shell",
      "command": "mvn compile",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$javac"
    }
  ]
}
